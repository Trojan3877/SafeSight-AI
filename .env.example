# SafeSight AI — Environment Variable Template
# Copy this file to .env and fill in the values before running the application.
# Never commit the .env file to version control.

# ─── API Server ───────────────────────────────────────────────────────────────

# Port the FastAPI server listens on (default: 8000)
PORT=8000

# Maximum accepted upload size in bytes (default: 10 MB)
MAX_FILE_SIZE_BYTES=10485760

# ─── Streamlit UI ─────────────────────────────────────────────────────────────

# Base URL of the FastAPI inference API (default: http://api:8000)
API_URL=http://localhost:8000

# Seconds before an API request times out (default: 30)
REQUEST_TIMEOUT_SECONDS=30

# ─── Detection Engine ─────────────────────────────────────────────────────────

# Minimum confidence score (0.0–1.0) to flag an event as a risk (default: 0.75)
DETECTION_THRESHOLD=0.75

# ─── Flask entrypoint (run.py only) ──────────────────────────────────────────
# Used only when starting the app via `python run.py` (Flask development server).
# The primary production entrypoint is FastAPI/uvicorn (see Procfile / Dockerfile).
# Set to "true" to enable Flask debug mode — NEVER true in production.
FLASK_DEBUG=false
